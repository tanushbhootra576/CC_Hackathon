{
  "buildCommand": "cd client && npm run build",
  "outputDirectory": "client/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://localhost:3000/api/:path*"
    }
  ],
  "env": {
    "NODE_ENV": "@node_env"
  },
  "functions": {
    "backend/**/*.js": {
      "runtime": "nodejs18.x"
    }
  }
}
